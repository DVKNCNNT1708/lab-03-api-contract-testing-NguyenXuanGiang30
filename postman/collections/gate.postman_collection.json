    {
      "name": "02_Auth",
      "item": [
        {
          "name": "GET /cards/{cardId} - valid token is accepted",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cards/RFID-2026-001",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cards",
                "RFID-2026-001"
              ]
            },
            "description": "Lấy thông tin thẻ với token hợp lệ."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Valid token request returns 200', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /cards/{cardId} - missing token is rejected on local service",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/cards/RFID-2026-001",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cards",
                "RFID-2026-001"
              ]
            },
            "description": "Auth test: thiếu token. Skip kiểm thử thật khi chạy Mock Server."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: Prism does not enforce real auth without custom rules', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Missing token returns 401 Unauthorized', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /cards/{cardId} - invalid token is rejected on local service",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid-jwt-token"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cards/RFID-2026-001",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cards",
                "RFID-2026-001"
              ]
            },
            "description": "Auth test: sai token. Skip kiểm thử thật khi chạy Mock Server."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "if (env === 'mock') {",
                  "  pm.test('Skipped on mock: invalid token rejection requires real auth provider', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Invalid token returns 401 Unauthorized', function () {",
                  "    pm.expect([401, 403]).to.include(pm.response.code);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
