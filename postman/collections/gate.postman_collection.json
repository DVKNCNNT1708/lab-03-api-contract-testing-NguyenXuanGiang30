              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response matches GateStatus schema', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('gateId', 'GATE-01');",
                  "  pm.expect(json).to.have.property('status');",
                  "  pm.expect(['OPEN', 'CLOSED', 'MAINTENANCE', 'ERROR']).to.include(json.status);",
                  "  pm.expect(json).to.have.property('lastUpdated');",
