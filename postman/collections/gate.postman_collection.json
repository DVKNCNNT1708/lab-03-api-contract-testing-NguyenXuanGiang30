                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response matches AccessEvent shape', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('eventType', 'ACCESS_CHECK');",
                  "  pm.expect(json).to.have.property('eventId');",
                  "  pm.expect(json).to.have.property('gateId');",
                  "  pm.expect(json).to.have.property('cardId');",
                  "  pm.expect(json).to.have.property('decision');",
                  "  pm.expect(json).to.have.property('timestamp');",
                  "});"
                ]
              }
            }
          ]
        },
